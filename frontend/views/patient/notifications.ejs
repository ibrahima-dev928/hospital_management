<%- include('../partials/header', { title: 'Notifications' , currentPath: '/patient/notifications' }) %>
  <div class="card">
    <h2>🔔 Mes notifications</h2>
    <% if (!notifs || notifs.length===0) { %>
      <p>Aucune notification.</p>
      <% } else { %>
        <ul>
          <% notifs.forEach(n=> { %>
            <li>
              <%= n.message %> - <small>
                  <%= new Date(n.created_at).toLocaleString() %>
                </small>
                <% if (n.lien) { %> <a href="<%= n.lien %>">Voir</a>
                  <% } %>
            </li>
            <% }) %>
        </ul>
        <% } %>
  </div>
  <%- include('../partials/footer') %>