<%- include('partials/header', { title: 'Statistiques' , currentPath: '/stats' }) %>

  <div class="content-header">
    <h1>📊 Tableau de bord - Statistiques</h1>
    <p>Vue d'ensemble des données de l'hôpital</p>
  </div>

  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-number">
        <%= totalPatients %>
      </div>
      <div class="stat-label">Patients</div>
    </div>
    <div class="stat-card">
      <div class="stat-number">
        <%= totalMedecins %>
      </div>
      <div class="stat-label">Médecins</div>
    </div>
    <div class="stat-card">
      <div class="stat-number">
        <%= rdvStats.total %>
      </div>
      <div class="stat-label">Rendez-vous</div>
    </div>
    <div class="stat-card">
      <div class="stat-number">
        <%= theme==='dark' ? '🌙' : '☀️' %>
      </div>
      <div class="stat-label">Thème</div>
    </div>
  </div>

  <div class="card">
    <h2>📈 Détail des rendez-vous</h2>
    <div class="stats-grid">
      <div class="stat-card" style="border-left-color: #28a745;">
        <div class="stat-number">
          <%= rdvStats.confirmes || 0 %>
        </div>
        <div class="stat-label">Confirmés</div>
      </div>
      <div class="stat-card" style="border-left-color: #ffc107;">
        <div class="stat-number">
          <%= rdvStats.en_attente || 0 %>
        </div>
        <div class="stat-label">En attente</div>
      </div>
      <div class="stat-card" style="border-left-color: #dc3545;">
        <div class="stat-number">
          <%= rdvStats.annules || 0 %>
        </div>
        <div class="stat-label">Annulés</div>
      </div>
    </div>
  </div>

  <div class="card">
    <h2>📋 Répartition par spécialité</h2>
    <table class="table">
      <thead>
        <tr>
          <th>Spécialité</th>
          <th>Nombre de médecins</th>
        </tr>
      </thead>
      <tbody>
        <% for(var spec in specialites) { %>
          <tr>
            <td>
              <%= spec %>
            </td>
            <td><strong>
                <%= specialites[spec] %>
              </strong></td>
          </tr>
          <% } %>
            <% if(Object.keys(specialites).length===0) { %>
              <tr>
                <td colspan="2">Aucune spécialité enregistrée</td>
              </tr>
              <% } %>
      </tbody>
    </table>
  </div>

  <%- include('partials/footer') %>