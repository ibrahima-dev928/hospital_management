<%- include('../partials/header', { title: `Modifier ${patient.prenom} ${patient.nom}`, currentPath: '/patients' }) %>
  <div class="card">
    <form action="/patients/update/<%= patient.id %>" method="POST">
      <div class="form-row">
        <input type="text" name="nom" value="<%= patient.nom %>" required>
        <input type="text" name="prenom" value="<%= patient.prenom %>" required>
      </div>
      <div class="form-row">
        <input type="date" name="date_naissance"
          value="<%= patient.date_naissance ? patient.date_naissance.toISOString().substr(0,10) : '' %>">
        <select name="genre">
          <option value="">Genre</option>
          <option value="M" <%=patient.genre==='M' ? 'selected' : '' %>>Masculin</option>
          <option value="F" <%=patient.genre==='F' ? 'selected' : '' %>>Féminin</option>
        </select>
      </div>
      <div class="form-row">
        <input type="tel" name="telephone" value="<%= patient.telephone || '' %>">
        <input type="email" name="email" value="<%= patient.email || '' %>">
      </div>
      <textarea name="adresse" rows="2"><%= patient.adresse || '' %></textarea>

      <!-- Bloc Informations médicales et sociales -->
      <h3>Informations médicales et sociales</h3>
      <div class="form-group">
        <label>Groupe sanguin</label>
        <select name="groupe_sanguin">
          <option value="">Non renseigné</option>
          <option value="A+" <%=patient.groupe_sanguin==='A+' ? 'selected' : '' %>>A+</option>
          <option value="A-" <%=patient.groupe_sanguin==='A-' ? 'selected' : '' %>>A-</option>
          <option value="B+" <%=patient.groupe_sanguin==='B+' ? 'selected' : '' %>>B+</option>
          <option value="B-" <%=patient.groupe_sanguin==='B-' ? 'selected' : '' %>>B-</option>
          <option value="AB+" <%=patient.groupe_sanguin==='AB+' ? 'selected' : '' %>>AB+</option>
          <option value="AB-" <%=patient.groupe_sanguin==='AB-' ? 'selected' : '' %>>AB-</option>
          <option value="O+" <%=patient.groupe_sanguin==='O+' ? 'selected' : '' %>>O+</option>
          <option value="O-" <%=patient.groupe_sanguin==='O-' ? 'selected' : '' %>>O-</option>
        </select>
      </div>
      <div class="form-group">
        <label>Allergies</label>
        <textarea name="allergies" rows="2"><%= patient.allergies || '' %></textarea>
      </div>
      <div class="form-group">
        <label>Antécédents médicaux</label>
        <textarea name="antecedents" rows="2"><%= patient.antecedents || '' %></textarea>
      </div>
      <div class="form-group">
        <label>Traitements en cours</label>
        <textarea name="traitements_en_cours" rows="2"><%= patient.traitements_en_cours || '' %></textarea>
      </div>
      <div class="form-group">
        <label>Médecin traitant</label>
        <select name="medecin_traitant_id">
          <option value="">Aucun</option>
          <% medecins.forEach(m=> { %>
            <option value="<%= m.id %>" <%=patient.medecin_traitant_id==m.id ? 'selected' : '' %>>
              Dr. <%= m.prenom %>
                <%= m.nom %> - <%= m.specialite %>
            </option>
            <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label>Profession</label>
        <input type="text" name="profession" value="<%= patient.profession || '' %>">
      </div>
      <div class="form-group">
        <label>Situation familiale</label>
        <input type="text" name="situation_familiale" value="<%= patient.situation_familiale || '' %>">
      </div>
      <div class="form-group">
        <label>Numéro de sécurité sociale</label>
        <input type="text" name="numero_securite_sociale" value="<%= patient.numero_securite_sociale || '' %>">
      </div>

      <button type="submit" class="btn-primary">💾 Enregistrer</button>
      <a href="/patients/view/<%= patient.id %>" class="btn-secondary">Annuler</a>
    </form>
  </div>
  <%- include('../partials/footer') %>