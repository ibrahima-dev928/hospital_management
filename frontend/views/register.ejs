<%- include('partials/header', { title: 'Inscription patient' }) %>
  <div class="card" style="max-width: 600px; margin: 50px auto;">
    <h2>Inscription</h2>
    <% if (locals.error) { %>
      <div class="error">
        <%= error %>
      </div>
      <% } %>
        <form action="/register" method="POST">
          <div class="form-row">
            <input type="text" name="username" placeholder="Nom d'utilisateur" required>
            <input type="email" name="email" placeholder="Email" required>
          </div>
          <div class="form-row">
            <input type="text" name="nom" placeholder="Nom" required>
            <input type="text" name="prenom" placeholder="Prénom" required>
          </div>
          <div class="form-row">
            <input type="tel" name="telephone" placeholder="Téléphone">
            <input type="date" name="date_naissance">
          </div>
          <div class="form-row">
            <input type="password" name="password" placeholder="Mot de passe" required>
            <input type="password" name="confirm_password" placeholder="Confirmer" required>
          </div>
          <textarea name="adresse" placeholder="Adresse"></textarea>
          <button type="submit" class="btn-primary">S'inscrire</button>
        </form>
        <p>Déjà inscrit ? <a href="/login">Connectez-vous</a></p>
  </div>
  <%- include('partials/footer') %>